# Copy this file to `.env` in the same folder (`hospital-flow-agent/`) and fill in values.
# Never commit `.env` (it is gitignored).
#
# IMPORTANT: the entire API key must be on ONE line after `OPENAI_API_KEY=`.
# Do not put `OPENAI_API_KEY=` on one line and the key on the next line — it will be ignored.

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional: folder containing observations.csv, patients.csv, encounters.csv
# SYNTHEA_DATA_DIR=/absolute/path/to/synthea/csv/folder
